# When you run `npm run dev` on your machine, MySQL must be reachable on localhost (compose maps 3307→3306).
DATABASE_URL="mysql://saas_pos_user:saas_pos_password@127.0.0.1:3307/saas_pos_db"
# Inside the Docker `app` container, compose sets DATABASE_URL to mysql:3306 — you do not need to change this file for Docker.
NEXT_PUBLIC_APP_NAME="saas-pos"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="change-this-jwt-secret"
# Email (Hostinger SMTP)
APP_URL="http://localhost:3000"
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="no-reply@pos.hssabaty.com"
SMTP_PASS="change-me"
MAIL_FROM="Hssabaty POS <no-reply@pos.hssabaty.com>"
MAIL_REPLY_TO="support@pos.hssabaty.com"
# Optional dev-only: comma-separated hostnames if Next blocks /_next assets when using a LAN/VPN IP (see next.config.ts).
# NEXT_DEV_EXTRA_ORIGINS="127.201.253.58,192.168.1.10"
