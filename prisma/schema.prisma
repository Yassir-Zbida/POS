generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum ProductType {
  SIMPLE
  VARIABLE
  SERVICE
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum MovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
  DAMAGE
  PURCHASE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT
}

enum SaleStatus {
  COMPLETED
  REFUNDED
  PARTIAL_REFUND
}

enum CouponType {
  PERCENT
  FIXED
}

enum CouponScope {
  ALL
  CATEGORY
  PRODUCT
}

enum POStatus {
  PENDING
  PARTIAL
  RECEIVED
  CANCELLED
}

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  CREDIT_OVERDUE
  SESSION_VARIANCE
  DAILY_SUMMARY
  STAFF_LOGIN
}

// ─────────────────────────────── Locations ───────────────────────────────────

model Location {
  id             String                @id @default(cuid())
  name           String
  address        String?
  phone          String?
  city           String?
  isActive       Boolean               @default(true)
  managerId      String?
  manager        User?                 @relation("LocationManager", fields: [managerId], references: [id])
  users          User[]                @relation("UserLocation")
  sessions       CashRegisterSession[]
  sales          Sale[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([managerId])
  @@index([isActive])
}

// ─────────────────────────────── Auth / Users ────────────────────────────────

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  phone               String?
  passwordHash        String?
  pinHash             String?
  pinAttempts         Int                  @default(0)
  pinLockedUntil      DateTime?
  role                UserRole             @default(CASHIER)
  status              UserStatus           @default(ACTIVE)
  otpEnabled          Boolean              @default(false)
  failedLoginAttempts Int                  @default(0)
  lockoutUntil        DateTime?
  ownerManagerId      String?
  ownerManager        User?                @relation("ManagerCashiers", fields: [ownerManagerId], references: [id])
  cashiers            User[]               @relation("ManagerCashiers")
  locationId          String?
  location            Location?            @relation("UserLocation", fields: [locationId], references: [id])
  managedLocations    Location[]           @relation("LocationManager")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditActions        AuditLog[]           @relation("AuditActor")
  subscriptions       Subscription[]       @relation("ManagerSubscription")
  cashSessions        CashRegisterSession[] @relation("SessionCashier")
  cashierSales        Sale[]               @relation("CashierSales")
  cashMovements       CashMovement[]       @relation("CashierMovements")
  stockMovements      InventoryMovement[]  @relation("MovementUser")
  creditPayments      CreditPayment[]      @relation("CashierCreditPayments")
  /** When true (e.g. admin-created merchant), block API access until first password change. */
  mustChangePassword  Boolean              @default(false)
  /** Last email+password (or OTP) sign-in for cashiers; PIN-only login allowed for 30 days after. */
  cashierFullAuthAt   DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([locationId])
}

model Subscription {
  id        String             @id @default(cuid())
  managerId String             @unique
  manager   User               @relation("ManagerSubscription", fields: [managerId], references: [id])
  status    SubscriptionStatus @default(ACTIVE)
  startedAt DateTime           @default(now())
  endedAt   DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique @db.VarChar(512)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// One-time codes for email/SMS verification (register, login step-up).
model OtpChallenge {
  id         String    @id @default(cuid())
  channel    String
  target     String
  purpose    String
  codeHash   String    @db.VarChar(128)
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([target, purpose, consumedAt])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actor       User     @relation("AuditActor", fields: [actorUserId], references: [id])
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────── Catalog ─────────────────────────────────────

model Category {
  id        String     @id @default(cuid())
  nameFr    String
  nameEn    String?
  nameAr    String?
  color     String?
  vatRate   Decimal?   @db.Decimal(5, 2)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// ─────────────────────────────── Attributes (WooCommerce-style) ──────────────

/// Global reusable attribute — e.g., "Color", "Size", "Material"
model Attribute {
  id        String             @id @default(cuid())
  name      String             @unique
  values    AttributeValue[]
  products  ProductAttribute[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

/// A specific value within an attribute — e.g., "Red", "Large"
model AttributeValue {
  id          String             @id @default(cuid())
  attributeId String
  attribute   Attribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  sortOrder   Int                @default(0)
  variants    VariantAttribute[]
  createdAt   DateTime           @default(now())

  @@unique([attributeId, value])
  @@index([attributeId])
}

/// Which attributes apply to a VARIABLE product
model ProductAttribute {
  productId   String
  attributeId String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([productId, attributeId])
}

/// Which attribute value a specific variant has (e.g., variant → Red + Large)
model VariantAttribute {
  variantId        String
  attributeValueId String
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@id([variantId, attributeValueId])
}

// ─────────────────────────────── Products ────────────────────────────────────

model Product {
  id          String              @id @default(cuid())
  type        ProductType         @default(SIMPLE)
  nameFr      String
  nameEn      String?
  nameAr      String?
  sku         String              @unique
  barcode     String?             @unique
  price       Decimal             @db.Decimal(10, 2)
  costPrice   Decimal?            @db.Decimal(10, 2)
  vatRate     Decimal             @default(20) @db.Decimal(5, 2)
  stock       Int                 @default(0)
  minStock    Int                 @default(0)
  imageUrl    String?
  /** Optional expiry date for perishable products (e.g. groceries). */
  expiryDate  DateTime?
  isActive    Boolean             @default(true)
  categoryId  String
  category    Category            @relation(fields: [categoryId], references: [id])
  attributes  ProductAttribute[]
  variants    ProductVariant[]
  saleItems   SaleItem[]
  movements   InventoryMovement[]
  poItems     PurchaseOrderItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([barcode])
  @@index([categoryId])
  @@index([type])
  @@index([expiryDate])
}

model ProductVariant {
  id            String             @id @default(cuid())
  productId     String
  product       Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Human-readable label, auto-generated from attribute values e.g. "Red / Large"
  name          String
  sku           String?            @unique
  barcode       String?            @unique
  priceOverride Decimal?           @db.Decimal(10, 2)
  costOverride  Decimal?           @db.Decimal(10, 2)
  stock         Int                @default(0)
  minStock      Int                @default(0)
  isActive      Boolean            @default(true)
  attributes    VariantAttribute[]
  saleItems     SaleItem[]
  poItems       PurchaseOrderItem[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([productId])
  @@index([sku])
}

// ─────────────────────────────── Inventory ───────────────────────────────────

model InventoryMovement {
  id        String       @id @default(cuid())
  productId String
  variantId String?
  type      MovementType
  qtyDelta  Int
  refId     String?
  refType   String?
  note      String?
  userId    String?
  product   Product      @relation(fields: [productId], references: [id])
  user      User?        @relation("MovementUser", fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@index([productId])
  @@index([createdAt])
}

// ─────────────────────────────── Customers ───────────────────────────────────

model Customer {
  id             String          @id @default(cuid())
  name           String
  phone          String?         @unique
  email          String?         @unique
  city           String?
  notes          String?         @db.Text
  tags           String?
  creditBalance  Decimal         @default(0) @db.Decimal(10, 2)
  loyaltyPoints  Int             @default(0)
  sales          Sale[]
  creditPayments CreditPayment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([phone])
  @@index([name])
}

model CreditPayment {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  amount     Decimal  @db.Decimal(10, 2)
  note       String?
  cashierId  String
  cashier    User     @relation("CashierCreditPayments", fields: [cashierId], references: [id])
  createdAt  DateTime @default(now())

  @@index([customerId])
}

// ─────────────────────────────── Cash Sessions ───────────────────────────────

model CashRegisterSession {
  id            String            @id @default(cuid())
  cashierId     String
  cashier       User              @relation("SessionCashier", fields: [cashierId], references: [id])
  locationId    String?
  location      Location?         @relation(fields: [locationId], references: [id])
  status        CashSessionStatus @default(OPEN)
  floatOpen     Decimal           @db.Decimal(10, 2)
  floatClose    Decimal?          @db.Decimal(10, 2)
  variance      Decimal?          @db.Decimal(10, 2)
  notes         String?
  openedAt      DateTime          @default(now())
  closedAt      DateTime?
  sales         Sale[]
  cashMovements CashMovement[]

  @@index([cashierId])
  @@index([locationId])
  @@index([status])
}

model CashMovement {
  id        String   @id @default(cuid())
  sessionId String
  session   CashRegisterSession @relation(fields: [sessionId], references: [id])
  type      String
  amount    Decimal  @db.Decimal(10, 2)
  reason    String?
  cashierId String
  cashier   User     @relation("CashierMovements", fields: [cashierId], references: [id])
  createdAt DateTime @default(now())

  @@index([sessionId])
}

// ─────────────────────────────── Sales ───────────────────────────────────────

model Sale {
  id             String               @id @default(cuid())
  sessionId      String?
  session        CashRegisterSession? @relation(fields: [sessionId], references: [id])
  locationId     String?
  location       Location?            @relation(fields: [locationId], references: [id])
  cashierId      String?
  cashier        User?                @relation("CashierSales", fields: [cashierId], references: [id])
  customerId     String?
  customer       Customer?            @relation(fields: [customerId], references: [id])
  couponId       String?
  coupon         Coupon?              @relation(fields: [couponId], references: [id])
  subtotal       Decimal              @db.Decimal(10, 2)
  discountAmt    Decimal              @default(0) @db.Decimal(10, 2)
  vatAmt         Decimal              @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal              @db.Decimal(10, 2)
  paymentMethod  PaymentMethod        @default(CASH)
  amountTendered Decimal?             @db.Decimal(10, 2)
  changeGiven    Decimal?             @db.Decimal(10, 2)
  notes          String?
  status         SaleStatus           @default(COMPLETED)
  items          SaleItem[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([sessionId])
  @@index([locationId])
  @@index([cashierId])
  @@index([customerId])
  @@index([createdAt])
}

model SaleItem {
  id          String          @id @default(cuid())
  saleId      String
  productId   String
  variantId   String?
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  discountAmt Decimal         @default(0) @db.Decimal(10, 2)
  totalPrice  Decimal         @db.Decimal(10, 2)
  sale        Sale            @relation(fields: [saleId], references: [id])
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ─────────────────────────────── Discounts ───────────────────────────────────

model Coupon {
  id        String      @id @default(cuid())
  code      String      @unique
  type      CouponType
  value     Decimal     @db.Decimal(10, 2)
  scope     CouponScope @default(ALL)
  scopeId   String?
  maxUses   Int?
  usedCount Int         @default(0)
  validFrom DateTime?
  validTo   DateTime?
  isActive  Boolean     @default(true)
  sales     Sale[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([code])
}

// ─────────────────────────────── Suppliers & POs ─────────────────────────────

model Supplier {
  id             String          @id @default(cuid())
  name           String
  phone          String?
  email          String?
  address        String?
  notes          String?         @db.Text
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String?
  supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  locationId  String?
  location    Location?           @relation(fields: [locationId], references: [id])
  status      POStatus            @default(PENDING)
  totalCost   Decimal             @db.Decimal(10, 2)
  notes       String?
  receivedAt  DateTime?
  createdById String?
  items       PurchaseOrderItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([supplierId])
  @@index([locationId])
  @@index([status])
}

model PurchaseOrderItem {
  id          String          @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  qtyOrdered  Int
  qtyReceived Int             @default(0)
  unitCost    Decimal         @db.Decimal(10, 2)
  order       PurchaseOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ─────────────────────────────── Notifications ───────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String           @db.Text
  isRead      Boolean          @default(false)
  refType     String?
  refId       String?
  triggeredAt DateTime         @default(now())

  @@index([isRead])
  @@index([triggeredAt])
}
